MONGODB_HOST=your-cluster.mongodb.net
MONGODB_USER=your_username
MONGODB_PASSWORD=your_password
MONGODB_DATABASE=your_database_name
MONGODB_SESSION_SECRET=your_session_encryption_secret
NODE_SESSION_SECRET=your_node_session_secret

MONGO_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/your_database_name